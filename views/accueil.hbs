{{#layout title="Accueil - Tunisie Tourisme"}}
<!DOCTYPE html>
<html>
<head>
  <title>Accueil - Tunisie Tourisme</title>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');
    body { font-family: 'Inter', sans-serif; }
    .bg-clip-text { -webkit-background-clip: text; background-clip: text; }
  </style>
</head>
<body class="bg-gray-50">
  <!-- Hero -->
  <section class="relative bg-gradient-to-br from-blue-900 via-purple-900 to-indigo-900 text-white overflow-hidden py-32">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-6xl md:text-7xl font-black mb-8 drop-shadow-2xl">
        Découvre <span class="bg-gradient-to-r from-yellow-400 to-orange-400 bg-clip-text text-transparent">Tunisie</span>
      </h1>
      <p class="text-2xl mb-12 max-w-3xl mx-auto opacity-95 leading-relaxed">
        24 Gouvernorats, des milliers de plans par guides locaux authentiques
      </p>
      <a href="#destinations" class="inline-block bg-white text-gray-900 px-12 py-6 rounded-full text-xl font-bold hover:bg-gray-100 transition-all shadow-2xl hover:shadow-3xl transform hover:-translate-y-2">
        🌍 Explorer
      </a>
    </div>
  </section>

  <!-- Gouvernorats -->
  <section id="destinations" class="py-24 bg-gray-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-5xl font-black text-gray-900 mb-6">📍 Nos 24 Gouvernorats</h2>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Cliquez sur "Voir les plans" pour découvrir les lieux incontournables !
        </p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-6">
        {{#each gouvernorats}}
        <a href="/plans/{{id}}" class="group card bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transform hover:-translate-y-4 transition-all duration-500 border-4 border-white hover:border-blue-300">
          <div class="h-48 bg-gradient-to-br from-gray-200 to-gray-300 group-hover:scale-110 transition-transform duration-500 overflow-hidden relative">
            <img src="{{image}}" alt="{{nom}}" class="w-full h-full object-cover group-hover:brightness-110">
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900 mb-3">{{nom}}</h3>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-black text-blue-600">{{#if nb_plans}}{{nb_plans}}{{else}}0{{/if}}</span>
              <button class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl font-bold text-sm transition-all">
                Voir les plans
              </button>
            </div>
          </div>
        </a>
        {{/each}}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-20">
        <h2 class="text-5xl font-black text-gray-900 mb-6">✨ Pourquoi nous ?</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-12">
        <div class="text-center group">
          <div class="w-24 h-24 bg-blue-100 rounded-3xl mx-auto mb-6 flex items-center justify-center group-hover:bg-blue-200 transition-all text-4xl">
            🗺️
          </div>
          <h3 class="text-2xl font-bold mb-4">Plans Locaux</h3>
          <p class="text-gray-600 text-lg">Guides tunisiens authentiques</p>
        </div>
        <div class="text-center group">
          <div class="w-24 h-24 bg-emerald-100 rounded-3xl mx-auto mb-6 flex items-center justify-center group-hover:bg-emerald-200 transition-all text-4xl">
            💳
          </div>
          <h3 class="text-2xl font-bold mb-4">Paiement Sécurisé</h3>
          <p class="text-gray-600 text-lg">Carte + PayPal Tunisie</p>
        </div>
        <div class="text-center group">
          <div class="w-24 h-24 bg-purple-100 rounded-3xl mx-auto mb-6 flex items-center justify-center group-hover:bg-purple-200 transition-all text-4xl">
            ⭐
          </div>
          <h3 class="text-2xl font-bold mb-4">Avis Vérifiés</h3>
          <p class="text-gray-600 text-lg">Notes et retours touristes</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation -->
  {{#if user}}
  <div class="fixed bottom-6 right-6">
    <a href="/{{user.role.toLowerCase}}/dashboard" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-full shadow-lg hover:shadow-xl transition-all">
      🏠 Mon Dashboard
    </a>
  </div>
  {{else}}
  <div class="fixed bottom-6 right-6 flex gap-3">
    <a href="/login" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-full shadow-lg hover:shadow-xl transition-all">
      🔐 Connexion
    </a>
    <a href="/register" class="bg-green-600 hover:bg-green-700 text-white px-6 py-3 rounded-full shadow-lg hover:shadow-xl transition-all">
      📝 Inscription
    </a>
  </div>
  {{/if}}
</body>
</html>
{{/layout}}

<!-- Features -->
<section class="features">
  <h2>Services</h2>
  <div class="grid-features">
    <div class="feature">
      <h3>Carte interactive</h3>
      <p>Localisez les destinations et les plans des guides.</p>
    </div>
    <div class="feature">
      <h3>Réservation en ligne</h3>
      <p>Sélectionnez un programme et réservez en quelques clics.</p>
    </div>
    <div class="feature">
      <h3>Diversité d'offres</h3>
      <p>Culture, nature, histoire et plus encore.</p>
    </div>
  </div>
</section>
